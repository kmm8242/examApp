<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The app is fully offline (questions ship in assets, no analytics, no backend).
         INTERNET is only needed in debug for Metro — strip it from release so the
         store listing shows zero network access. Delete this line if a backend or
         crash reporter is ever added. -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
</manifest>
