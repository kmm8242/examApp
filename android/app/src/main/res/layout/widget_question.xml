<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_subject_tag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Study"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:singleLine="true" />

        <Button
            android:id="@+id/widget_btn_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next →"
            android:textColor="#4F46E5"
            android:textSize="11sp"
            android:background="@android:color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_question_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Loading question…"
        android:textColor="#111827"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.35"
        android:ellipsize="end"
        android:maxLines="5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/widget_opt_a"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="A"
            android:textSize="11sp"
            android:textColor="#374151"
            android:background="@drawable/widget_opt_default"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/widget_opt_b"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:text="B"
            android:textSize="11sp"
            android:textColor="#374151"
            android:background="@drawable/widget_opt_default"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/widget_opt_c"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="C"
            android:textSize="11sp"
            android:textColor="#374151"
            android:background="@drawable/widget_opt_default"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/widget_opt_d"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:text="D"
            android:textSize="11sp"
            android:textColor="#374151"
            android:background="@drawable/widget_opt_default"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </LinearLayout>
</LinearLayout>
